### 6.2 Gallery Web：SWR 與 CSS 優化
**[MODIFY] `apps/gallery-web/src/hooks/useGalleryPolling.ts`**
```typescript
import useSWR from 'swr';
import { GalleryItem } from '../types';

const API_URL = import.meta.env.VITE_API_BASE_URL || '';
const fetcher = (url: string) => fetch(url).then(r => r.json());

export function useGalleryPolling() {
  const { data, error } = useSWR<GalleryItem[]>(`${API_URL}/api/gallery`, fetcher, {
    refreshInterval: 10000,
  });

  const videos = data?.filter(v => v.video_url) || [];
  return { videos, isLoaded: !!data || !!error };
}
```

**[MODIFY] `apps/gallery-web/src/App.tsx`**
1. 刪除 `<style>` 標籤，將 `@keyframes` 移至 `index.css`。
2. 將 `style={{ position: 'absolute', ... }}` 改寫為 `<div className="absolute top-0 left-0 w-[220px] ...">`。

