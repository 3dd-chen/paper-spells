# ─── Cloudflare R2 (Object Storage) ──────────────────────────────────────────
# 僅用於本地開發測試（在 Cloudflare Workers 上，R2 是透過 Binding 直接存取，不需要這些金鑰）
# Create R2 API tokens at: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=paper-spells-media
# 設定你的 R2 公開網域（在 R2 Bucket Settings 綁定 Custom Domain 後設定）
R2_PUBLIC_URL=media.yourdomain.com

# ─── Cloudflare D1 & Workers (for CI/CD) ─────────────────────────────────────
# 用於 GitHub Actions 自動部署，也可用於本地 wrangler 指令
# 在 Cloudflare Dashboard → My Profile → API Tokens 建立
CF_API_TOKEN=your_cloudflare_api_token
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_D1_DATABASE_ID=your_d1_database_id

# ─── GCP / Vertex AI (Gemini + Veo video generation) ─────────────────────────
# 在 GCP Console → APIs & Services → Credentials 建立 API Key
# 確保已啟用 Vertex AI API 並綁定帳單
GEMINI_API_KEY=your_gcp_api_key
GCP_PROJECT_ID=your_gcp_project_id

# ─── App Settings ─────────────────────────────────────────────────────────────
# AI_PROVIDER=mock    ← 本地開發不想跑 Veo 時，切換成 mock 省費用
AI_PROVIDER=gemini
