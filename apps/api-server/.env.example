# ─── Cloudflare R2 (Object Storage) ──────────────────────────────────────────
# Create R2 API tokens at: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
# Set this to your custom domain after binding it in the R2 bucket settings
R2_PUBLIC_URL=media.yourdomain.com

# ─── GCP / Vertex AI (Veo video generation) ──────────────────────────────────
# Path to downloaded service account JSON key file (relative to api-server/)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# ─── GCS Bucket (Veo writes output videos here) ──────────────────────────────
GCS_OUTPUT_BUCKET_URI=gs://your-gcs-bucket/videos/

# ─── App Settings ─────────────────────────────────────────────────────────────
# AI_PROVIDER=mock    ← use this for local dev without GCP
AI_PROVIDER=gemini
